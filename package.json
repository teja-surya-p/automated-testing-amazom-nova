{
  "name": "automated-testing",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "predev": "node scripts/check-port-3000.mjs",
    "dev": "concurrently -n backend,frontend -c '#f97316,#f4d35e' \"npm run dev --workspace @qa/server\" \"npm run dev --workspace @qa/dashboard\"",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspace @qa/server",
    "start": "npm run start --workspace @qa/server",

    "ports:kill": "npx kill-port 3000 3001 || true",
    "clean": "npm run ports:kill",
    "demo": "npm run clean && npm run dev",
    "smoke": "node -e \"Promise.all([3000,3001].map(p=>fetch('http://localhost:'+p).then(r=>console.log(p,r.status)).catch(()=>console.log(p,'DOWN'))))\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.1000.0"
  }
}
